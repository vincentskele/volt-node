# Main Volt server. Your node uses this to discover other nodes and fall back to the execution layer.
VOLT_NODE_BASE_URL=https://volt.example.com

# Node auth key from VoltScan -> Node Key. Leave blank if you want first boot to prompt for it.
VOLT_NODE_AUTH_KEY=

# Optional explicit execution-layer status URL.
VOLT_NODE_PRIMARY_STATUS_URL=https://volt.example.com/node/status

# Optional discovery endpoint override. Usually this is derived from VOLT_NODE_BASE_URL.
VOLT_NODE_DISCOVERY_URL=https://volt.example.com/api/nodes

# Optional manual node overrides. Most users should leave this blank.
VOLT_NODE_PEERS=https://peer-1.example.com,https://peer-2.example.com

# Optional node presence endpoints. Usually derived from VOLT_NODE_BASE_URL.
VOLT_NODE_REGISTER_URL=https://volt.example.com/api/nodes/register
VOLT_NODE_HEARTBEAT_URL=https://volt.example.com/api/nodes/heartbeat

# Optional report-back endpoint so this node can tell the execution layer whether consensus agrees.
VOLT_NODE_REPORT_URL=https://volt.example.com/api/consensus/report

# Optional shared secret if the execution layer protects consensus reports.
VOLT_NODE_REPORT_KEY=

# Optional public URL for this node if other peers should reach it directly.
VOLT_NODE_PUBLIC_URL=

# Optional local node identity overrides.
VOLT_NODE_NAME=
VOLT_NODE_ID=
VOLT_NODE_ROLE=consensus

# Optional local dashboard binding.
VOLT_NODE_STATUS_HOST=127.0.0.1
VOLT_NODE_STATUS_PORT=8788

# Optional sync loop interval in milliseconds.
VOLT_NODE_SYNC_INTERVAL_MS=30000
